# Sanity project credentials
VITE_SANITY_PROJECT_ID=your_project_id
VITE_SANITY_DATASET=production

# Neo4j Aura — read-only user for browser queries (VITE_ prefix exposes to frontend)
VITE_NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
VITE_NEO4J_USERNAME=milorg_reader
VITE_NEO4J_PASSWORD=your-readonly-password

# Neo4j Aura — admin user for import scripts only (never exposed to browser)
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-admin-password
